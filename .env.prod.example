NODE_ENV=production

# Telegram
BOT_TOKEN=replace_with_telegram_bot_token
BOT_ENABLED=true
TELEGRAM_PROXY_URL=http://proxy_user:proxy_password@proxy_host:proxy_port
ADMIN_CHAT_ID=
WEB_APP_URL=https://your-public-domain.example

# Application
API_PORT=3000
WEB_PORT=8080

# Prisma URLs use the Docker service name "mysql".
# URL-encode special characters in the username/password.
DATABASE_URL=mysql://sanctum_user:replace_with_db_password@mysql:3306/Sanctum_clinic
SHADOW_DATABASE_URL=mysql://sanctum_user:replace_with_db_password@mysql:3306/Sanctum_clinic_shadow

# MySQL
MYSQL_DATABASE=Sanctum_clinic
MYSQL_USER=sanctum_user
MYSQL_PASSWORD=replace_with_db_password
MYSQL_ROOT_PASSWORD=replace_with_root_password
