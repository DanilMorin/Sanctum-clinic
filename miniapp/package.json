{
  "name": "sanctum-clinic-miniapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test": "node --test",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.js\" \"*.js\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.js\" \"test/**/*.js\" \"*.js\" \"*.json\"",
    "check": "npm run lint && npm run format:check && npm test && npm run build"
  },
  "devDependencies": {
    "eslint": "^10.7.0",
    "prettier": "^3.9.6",
    "sass": "^1.89.2",
    "vite": "^6.0.0"
  }
}
