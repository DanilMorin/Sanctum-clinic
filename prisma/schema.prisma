generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum QuizSessionStatus {
  started
  completed
  abandoned
}

enum SkinType {
  oily
  combination
  dry
}

enum SkinFeature {
  acne
  rosacea
  couperose
  pigmentation
  sensitive
  none
}

enum Lifestyle {
  active
  normal
  any
}

enum SpfUsage {
  makeup_base
  standalone
}

enum ProductFormat {
  pharmacy
  professional
  both
}

enum ProductCategory {
  pharmacy
  professional
}

model User {
  id Int @id @default(autoincrement())

  telegramId String? @unique
  maxId      String? @unique

  username  String?
  firstName String?
  lastName  String?

  quizSessions QuizSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model QuizSession {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  status QuizSessionStatus @default(started)

  skinType        SkinType?
  skinFeatures    Json?
  priorityFeature SkinFeature?
  lifestyle       Lifestyle?
  spfUsage        SpfUsage?
  productFormat   ProductFormat?

  recommendationRuleId Int?
  recommendationRule   RecommendationRule? @relation(fields: [recommendationRuleId], references: [id], onDelete: SetNull)

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([recommendationRuleId])
  @@map("quiz_sessions")
}

model Product {
  id Int @id @default(autoincrement())

  name     String
  brand    String?
  category ProductCategory

  spf          String?
  texture      String?
  isMakeupBase Boolean?

  description   String? @db.Text
  doctorComment String? @db.Text
  imageUrl      String?

  mainForRules         RecommendationRule[] @relation("MainProduct")
  professionalForRules RecommendationRule[] @relation("ProfessionalProduct")
  alternatives         RecommendationAlternative[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("products")
}

model RecommendationRule {
  id Int @id @default(autoincrement())

  skinType        SkinType
  priorityFeature SkinFeature
  lifestyle       Lifestyle

  mainProductId Int?
  mainProduct   Product? @relation("MainProduct", fields: [mainProductId], references: [id], onDelete: SetNull)

  professionalProductId Int?
  professionalProduct   Product? @relation("ProfessionalProduct", fields: [professionalProductId], references: [id], onDelete: SetNull)

  alternatives RecommendationAlternative[]
  quizSessions QuizSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mainProductId])
  @@index([professionalProductId])
  @@unique([skinType, priorityFeature, lifestyle])
  @@map("recommendation_rules")
}

model RecommendationAlternative {
  id Int @id @default(autoincrement())

  recommendationRuleId Int
  recommendationRule   RecommendationRule @relation(fields: [recommendationRuleId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([recommendationRuleId, productId])
  @@index([productId])
  @@map("recommendation_alternatives")
}